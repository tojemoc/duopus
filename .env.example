# Phase 1 (SQLite) — copy to `.env` and adjust. `SECRET_KEY` is required for the API to start.
DATABASE_URL=sqlite+aiosqlite:///./duopus.db
SECRET_KEY=change-me-to-a-long-random-string

# --- Docker Compose (full stack) — optional; Compose also supplies dev-safe defaults in docker-compose.yml.
# Override POSTGRES_PASSWORD (and POSTGRES_URL on the backend) together if you change the DB password.
# POSTGRES_USER=duopus
# POSTGRES_PASSWORD=duopus_local_dev
# POSTGRES_URL=postgresql+psycopg://duopus:duopus_local_dev@db:5432/duopus
# When the FastAPI app should use Postgres (requires async driver in backend requirements), set:
# DATABASE_URL=postgresql+asyncpg://duopus:duopus_local_dev@db:5432/duopus
# Prebuilt images from GHCR (defaults point at upstream); for a fork use your own registry:
# DUOPUS_BACKEND_IMAGE=ghcr.io/your-org/duopus-backend:latest
# DUOPUS_NGINX_IMAGE=ghcr.io/your-org/duopus-nginx:latest
# Required when ENVIRONMENT=production (seeds initial admin user)
# ADMIN_PASSWORD=

# development | production
ENVIRONMENT=development

CORS_ORIGINS=http://localhost:5173
AUTOGEN_TIME_UTC=03:00

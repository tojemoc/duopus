# Phase 1 (SQLite) — copy to `.env` and adjust. `SECRET_KEY` is required for the API to start.
DATABASE_URL=sqlite+aiosqlite:///./duopus.db
SECRET_KEY=change-me-to-a-long-random-string
# Default dev admin (see docs/PHASE1.md): admin@example.com / duopus2025 unless you set:
# ADMIN_PASSWORD=

# development | production
ENVIRONMENT=development

CORS_ORIGINS=http://localhost:5173
AUTOGEN_TIME_UTC=03:00
